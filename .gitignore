```gitignore
# Python cache
*/__pycache__/*
*.pyc

# Node modules
node_modules/

# Logs
*.log

# Environment files
.env
.env.local
*.env.*

# IDE and editor settings
.vscode/
.idea/

# Temporary files
*.tmp
*.swp

# Build artifacts
dist/
build/
target/

# Dependency caches
.venv/
venv/
.mypy_cache/
.pytest_cache/
.gradle/

# OS generated files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst

```